# ==========================================
# 通用/IDE 配置
# ==========================================
.idea/
.vscode/
*.swp
*.bak
*.tmp
.DS_Store
Thumbs.db
*.orig

# ==========================================
# 后端配置 (Python/FastAPI)
# ==========================================
# Python 缓存
backend/**/*.pyc
backend/__pycache__/
backend/**/*.pyo
backend/.pytest_cache/
backend/.mypy_cache/
backend/*.egg-info/
backend/*.egg

# 虚拟环境
backend/venv/
backend/.venv/
backend/env/
backend/.env/

# 环境变量（但保留 .env.example）
backend/.env
backend/.env.local
backend/.env.production

# 日志文件
backend/logs/
backend/*.log

# 上传和存储文件
backend/uploads/
backend/storage/

# 数据库文件（PostgreSQL 数据除外）
backend/*.sqlite3
backend/*.db

# ==========================================
# 前端配置 (Node/Angular)
# ==========================================
# 依赖
frontend/node_modules/
frontend/dist/
frontend/.angular/

# 日志与缓存
frontend/*.log
frontend/npm-debug.log*
frontend/yarn-debug.log*
frontend/yarn-error.log*
frontend/.eslintcache
frontend/.cache/

# 构建产物
frontend/www/
frontend/.ng_build/

# ==========================================
# 数据库配置
# ==========================================
# 数据库备份和导出（PostgreSQL 数据目录除外）
*.sql
*.db
*.sqlite
*.sqlite3

# ==========================================
# 敏感信息
# ==========================================
# API Keys 和密钥
**/.env
**/.env.local
**/.env.production
**/secrets/
**/keys/
**/*.key
**/*.pem
**/*.crt

# ==========================================
# 构建产物
# ==========================================
# 编译输出
**/build/
**/dist/
**/out/
**/target/

# ==========================================
# 临时文件
# ==========================================
*.tmp
*.temp
*.swp
*.swo
*~
*.orig

# ==========================================
# 测试和覆盖率
# ==========================================
**/test-results/
**/coverage/
**/.coverage
**/htmlcov/
**/.tox/

# ==========================================
# Docker
# ==========================================
**/.docker/
**/docker-compose.override.yml

# ==========================================
# 文档生成
# ==========================================
**/site/
**/docs/_build/

# ==========================================
# 大型媒体文件（可选）
# ==========================================
# *.mp4
# *.avi
# *.mov
# *.mkv
# *.mp3
# *.wav

# ==========================================
# IDE 特定配置
# ==========================================
# IntelliJ IDEA
**/.iml
**/.ipr
**/.iws

# Visual Studio
**/.vs/
**/*.user
**/*.suo

# Eclipse
**/.project
**/.classpath
**/.settings/
